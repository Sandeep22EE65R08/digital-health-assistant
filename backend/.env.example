# Copy this file to `.env` and fill in the real values.
# `.env` is gitignored so your secrets stay local / are set in the host's dashboard.

# OpenAI-compatible chat-completions endpoint.
# For Google Gemini (free tier):
#   https://generativelanguage.googleapis.com/v1beta/openai
AI_API_BASE=https://generativelanguage.googleapis.com/v1beta/openai

# Model name. Gemini examples: gemini-2.5-flash, gemini-2.0-flash
AI_API_MODEL=gemini-2.5-flash

# Your API key. Leave empty to run the app in safe demo (rule-based) mode.
AI_API_KEY=


# Server bind. In production (Render/Heroku/Fly) the platform sets $PORT and
# the app will bind 0.0.0.0 automatically when FLASK_ENV != "development".
HOST=127.0.0.1
PORT=5000
